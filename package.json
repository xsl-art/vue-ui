{
  "name": "vue-ui",
  "private": false,
  "version": "0.1.2",
  "type": "module",
  "description": "A lightweight Vue 3 component library built with TypeScript and Vite.",
  "main": "dist/umd/index.umd.js",
  "module": "dist/es/index.mjs",
  "types": "dist/types/index.d.ts",
  "style": "dist/style.css",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/umd/index.umd.js"
    },
    "./style.css": "./dist/style.css",
    "./es/components/*/style.css": "./dist/es/components/*/style.css",
    "./es/components/*": {
      "types": "./dist/types/components/*/index.d.ts",
      "import": "./dist/es/components/*/index.mjs"
    },
    "./alert": {
      "types": "./dist/types/components/Alert/index.d.ts",
      "import": "./dist/es/components/Alert/index.mjs"
    },
    "./alert/style.css": "./dist/es/components/Alert/style.css",
    "./button": {
      "types": "./dist/types/components/Button/index.d.ts",
      "import": "./dist/es/components/Button/index.mjs"
    },
    "./button/style.css": "./dist/es/components/Button/style.css",
    "./collapse": {
      "types": "./dist/types/components/Collapse/index.d.ts",
      "import": "./dist/es/components/Collapse/index.mjs"
    },
    "./collapse/style.css": "./dist/es/components/Collapse/style.css",
    "./dialog": {
      "types": "./dist/types/components/Dialog/index.d.ts",
      "import": "./dist/es/components/Dialog/index.mjs"
    },
    "./dialog/style.css": "./dist/es/components/Dialog/style.css",
    "./dropdown": {
      "types": "./dist/types/components/Dropdown/index.d.ts",
      "import": "./dist/es/components/Dropdown/index.mjs"
    },
    "./dropdown/style.css": "./dist/es/components/Dropdown/style.css",
    "./form": {
      "types": "./dist/types/components/Form/index.d.ts",
      "import": "./dist/es/components/Form/index.mjs"
    },
    "./form/style.css": "./dist/es/components/Form/style.css",
    "./icon": {
      "types": "./dist/types/components/Icon/index.d.ts",
      "import": "./dist/es/components/Icon/index.mjs"
    },
    "./icon/style.css": "./dist/es/components/Icon/style.css",
    "./input": {
      "types": "./dist/types/components/Input/index.d.ts",
      "import": "./dist/es/components/Input/index.mjs"
    },
    "./input/style.css": "./dist/es/components/Input/style.css",
    "./message": {
      "types": "./dist/types/components/Message/index.d.ts",
      "import": "./dist/es/components/Message/index.mjs"
    },
    "./message/style.css": "./dist/es/components/Message/style.css",
    "./select": {
      "types": "./dist/types/components/Select/index.d.ts",
      "import": "./dist/es/components/Select/index.mjs"
    },
    "./select/style.css": "./dist/es/components/Select/style.css",
    "./switch": {
      "types": "./dist/types/components/Switch/index.d.ts",
      "import": "./dist/es/components/Switch/index.mjs"
    },
    "./switch/style.css": "./dist/es/components/Switch/style.css",
    "./tag": {
      "types": "./dist/types/components/Tag/index.d.ts",
      "import": "./dist/es/components/Tag/index.mjs"
    },
    "./tag/style.css": "./dist/es/components/Tag/style.css",
    "./tooltip": {
      "types": "./dist/types/components/Tooltip/index.d.ts",
      "import": "./dist/es/components/Tooltip/index.mjs"
    },
    "./tooltip/style.css": "./dist/es/components/Tooltip/style.css",
    "./resolver": {
      "types": "./dist/types/resolver/index.d.ts",
      "import": "./dist/es/resolver/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "dist/**/*.css",
    "dist/**/*.scss",
    "dist/umd/*.js"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib && pnpm build:types && pnpm build:components",
    "build:lib": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:components": "node scripts/build-components.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@popperjs/core": "^2.11.8",
    "async-validator": "^4.2.5",
    "lodash-es": "^4.18.1"
  },
  "peerDependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@algolia/client-search": "^5.52.1",
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/compiler-dom": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "search-insights": "^2.17.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "10",
    "vue-tsc": "^3.2.7"
  }
}